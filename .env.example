# ─── Database ────────────────────────────────────────────────────────────────
# Used by the app at runtime and by drizzle-kit for migrations.
# For Docker Compose the host is the service name "db".
DATABASE_URL=mysql://app:apppassword@db:3306/driveway

# ─── MySQL (Docker Compose only) ─────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=driveway
MYSQL_USER=app
MYSQL_PASSWORD=apppassword

# ─── Auth / Sessions ─────────────────────────────────────────────────────────
# Random secret used to sign JWT session cookies.  Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_32_byte_hex_string

# ─── App Identity ────────────────────────────────────────────────────────────
# Public app identifier used inside signed session tokens.
APP_ID=your_app_id

# ─── OpenAPI Services ────────────────────────────────────────────────────────
# Base URL for the OpenAPI gateway providing LLM, storage, and data services.
OPENAPI_BASE_URL=https://api.example.com
OPENAPI_API_KEY=your_openapi_api_key
# Optional path overrides (defaults shown below)
OPENAPI_DATA_API_PATH=/data/execute
OPENAPI_LLM_PATH=/llm/chat/completions
OPENAPI_STORAGE_PRESIGN_PUT_PATH=/storage/presign/put
OPENAPI_STORAGE_PRESIGN_GET_PATH=/storage/presign/get

# ─── OpenAI (recommended for AI features) ────────────────────────────────────
# Use the GenSpark-provided OpenAI-compatible gateway when available.
OPENAI_BASE_URL=https://www.genspark.ai/api/llm_proxy/v1
OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_COMPLETIONS_PATH=/chat/completions
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TRANSCRIPTION_MODEL=whisper-1
# Optional: override the default model used for chat completions
LLM_MODEL=gpt-5-mini

# ─── Built-in Forge Services (optional) ──────────────────────────────────────
# Needed if you use the internal ImageService / notification / maps proxy.
BUILT_IN_FORGE_API_URL=https://api.example.com
BUILT_IN_FORGE_API_KEY=your_forge_api_key

# Public app URL used in notifications and share links
APP_BASE_URL=https://your-production-app.example.com

# ─── Owner bootstrap ─────────────────────────────────────────────────────────
# Optional: this email is granted admin access when the account is created.
OWNER_EMAIL=owner@example.com

# ─── App (optional) ──────────────────────────────────────────────────────────
PORT=3000
HOST=127.0.0.1
APP_PORT=3000          # host port mapped in docker-compose

# Public HTTPS origin for native mobile builds. Required when building an APK
# with bundled web assets, because the app cannot call same-origin /api routes
# from the Capacitor localhost origin.
PUBLIC_API_BASE_URL=https://your-production-app.example.com

# Comma-separated extra origins allowed to call the API with credentials.
# Keep this tight; do not use wildcards.
MOBILE_ALLOWED_ORIGINS=https://your-production-app.example.com
